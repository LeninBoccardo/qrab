{
  "name": "qrab",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "tauri": "tauri",
    "lint": "tsc --noEmit",
    "fmt": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\"",
    "fmt:check": "prettier --check \"src/**/*.{ts,tsx,css,html,json}\"",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "fmt:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "icons": "node scripts/extract-icons.mjs",
    "icons:preview": "node scripts/extract-icons.mjs --preview"
  },
  "license": "MIT",
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-log": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "lucide-solid": "^1.16.0",
    "solid-js": "^1.9.3",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.6"
  }
}
